{
  "name": "meka-flow",
  "version": "1.0.0",
  "license": "MIT",
  "repository": "github:osvald-go2/meka-flow",
  "homepage": "https://github.com/osvald-go2/meka-flow",
  "bugs": "https://github.com/osvald-go2/meka-flow/issues",
  "keywords": ["ai", "meka-flow", "react", "electron", "gemini"],
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:rust": "cd ai-backend && cargo build",
    "dev:electron": "npm run build:rust && electron-vite dev",
    "build:electron": "npm run build:rust -- --release && electron-vite build",
    "pack": "electron-builder --dir",
    "dist": "npm run build:electron && electron-builder --mac dmg",
    "preview:electron": "electron-vite preview",
    "postinstall": "electron-rebuild && chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "^6.2.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0"
  },
  "build": {
    "appId": "com.mekaflow.app",
    "productName": "Meka Flow",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "ai-backend/target/release/ai-backend",
        "to": "ai-backend"
      },
      {
        "from": "dynamic-island/out",
        "to": "dynamic-island/out"
      },
      {
        "from": "dynamic-island/resources",
        "to": "dynamic-island/resources"
      }
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "Meka Flow",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
